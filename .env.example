APP_ENV=staging
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Polygon.io
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_BASE_URL=https://api.polygon.io

# IBKR
IBKR_ENABLED=false
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# Paper Trading
PAPER_TRADE_ENABLED=true
PAPER_TRADE_INITIAL_BALANCE=100000.00

# MySQL
MYSQL_HOST=smv_mysql
MYSQL_PORT=3306
MYSQL_DATABASE=smv_trades
MYSQL_USER=smv_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# Redis
REDIS_HOST=smv_redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis

# MongoDB
MONGO_HOST=smv_mongo
MONGO_PORT=27017
MONGO_USER=smv_mongo
MONGO_PASSWORD=change_me_mongo
MONGO_DATABASE=smv

# Ollama
OLLAMA_BASE_URL=http://smv_ollama:11434
OLLAMA_MODEL=gemma4:e4b
